{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "assigneesFromCodeOwners": true,
  "automergeStrategy": "auto",
  "automergeType": "pr",
  "prConcurrentLimit": 5,
  "ignoreTests": false,
  "rebaseLabel": "needs-rebase",
  "rebaseWhen": "behind-base-branch",
  "recreateWhen": "always",
  "commitMessageSuffix": "{{baseBranch}}",
  "git-submodules": {
    "enabled": true,
    "schedule": "* 4 * * 2",
    "packageRules": [
      {
        "matchUpdateTypes": [
          "minor",
          "patch",
          "pin",
          "digest"
        ],
        "automerge": true,
        "addLabels": [
          "lgtm",
          "approved"
        ]
      }
    ]
  },
  "tekton": {
    "enabled": true,
    "packageRules": [
      {
        "matchUpdateTypes": [
          "minor",
          "patch",
          "pin",
          "digest"
        ],
        "automerge": true,
        "addLabels": [
          "lgtm",
          "approved"
        ]
      }
    ]
  },
  "dockerfile": {
    "enabled": true,
    "packageRules": [
      {
        "matchFileNames": [
          "Dockerfile*",
          "*.Dockerfile"
        ],
        "automerge": true,
        "addLabels": [
          "lgtm",
          "approved"
        ]
      }
    ]
  },
  "gomod": {
    "enabled": false
  },
  "vulnerabilityAlerts": {
    "enabled": true
  }
}
